# Supabase — récupérez ces valeurs dans : Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_publique

# Clé service_role (serveur uniquement — NE JAMAIS exposer côté client)
# Nécessaire pour la page admin et la table reveal_settings
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role

# Date et heure de la révélation (fallback si reveal_settings vide)
NEXT_PUBLIC_REVEAL_DATE=2026-07-15T18:00:00+02:00

# Résultat secret (fallback) — valeurs : fille | garcon
REVEAL_RESULT=fille

# Prénoms secrets pour le jeu (serveur uniquement — jamais NEXT_PUBLIC_)
BABY_NAME_FILLE=Leïlany
BABY_NAME_GARCON=Shayonn

# Début du jeu des lettres (optionnel — défaut : 12 semaines avant la révélation)
# MYSTERY_NAME_START_DATE=2026-04-01T08:00:00+02:00

# Activer le jeu du prénom sur le site (défaut : désactivé — activez via /admin)
# NAME_GAME_ENABLED=true

# URL publique du site (pour le partage social)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mot de passe de la page admin (/admin)
ADMIN_PASSWORD=choisissez-un-mot-de-passe-fort
